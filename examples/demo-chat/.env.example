# WhatsApp Business API credentials
CLOUD_API_ACCESS_TOKEN=your_access_token
WA_PHONE_NUMBER_ID=your_phone_number_id
WA_BUSINESS_ACCOUNT_ID=your_business_account_id

# Webhook verification
WEBHOOK_VERIFICATION_TOKEN=your_custom_verification_token

# Meta App Secret (for X-Hub-Signature-256 verification)
APP_SECRET=your_app_secret

# Optional: Webhook URL (for display in startup log)
WEBHOOK_URL=https://your-tunnel-url.ngrok-free.app

# Supabase (required for message persistence + realtime)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
