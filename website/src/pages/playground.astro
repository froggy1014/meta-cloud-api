---
import Playground from '../components/playground/Playground';
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Playground — meta-cloud-api</title>
    <meta name="description" content="Try the meta-cloud-api SDK in your browser with an interactive code editor" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body>
    <div class="page">
        <header>
            <a href="/" class="logo-link">
                <img src="/logo.svg" alt="" width="24" height="24" />
                <span class="logo-text">meta-cloud-api</span>
            </a>
            <nav>
                <a href="/getting-started/introduction">Docs</a>
                <a href="/api/messages">API</a>
                <a href="/playground" class="active">Playground</a>
                <a href="https://github.com/froggy1014/meta-cloud-api" target="_blank" rel="noopener">GitHub</a>
            </nav>
        </header>

        <main>
            <div class="hero-section">
                <h1>Playground</h1>
                <p class="subtitle">Try the SDK in your browser — edit the JSON payload and click <strong>Run</strong> to send real API requests with your own key.</p>
            </div>

            <div class="callout">
                <div class="callout-icon">💬</div>
                <div class="callout-content">
                    <strong>Before you send messages</strong>
                    <p>WhatsApp requires an active <a href="https://developers.facebook.com/docs/whatsapp/conversation-types#customer-service-windows" target="_blank" rel="noopener">24-hour conversation window</a> to send non-template messages. The recipient must message your business number first. Template messages (like <code>hello_world</code>) can be sent anytime without an open window — but note that template messages incur <a href="https://developers.facebook.com/docs/whatsapp/pricing" target="_blank" rel="noopener">per-conversation charges</a> based on the recipient's country.</p>
                </div>
            </div>

            <div class="playground-wrapper">
                <Playground client:only="react" />
            </div>

            <div class="info-section">
                <div class="info-card">
                    <div class="info-card-step">1</div>
                    <h3>Open the window</h3>
                    <p>Send a WhatsApp message to your business number from the recipient's phone. This opens a 24-hour window.</p>
                </div>
                <div class="info-card">
                    <div class="info-card-step">2</div>
                    <h3>Add your API key</h3>
                    <p>Click <strong>Settings</strong> and enter your Access Token and Phone Number ID. Credentials stay in your browser only.</p>
                </div>
                <div class="info-card">
                    <div class="info-card-step">3</div>
                    <h3>Send a message</h3>
                    <p>Edit the JSON payload, click <strong>Run (Live)</strong>, and check the Response tab. Or use <strong>cURL</strong> tab to copy the command.</p>
                </div>
            </div>
        </main>

        <footer>
            <span>meta-cloud-api</span>
            <span class="sep">·</span>
            <a href="https://github.com/froggy1014/meta-cloud-api">GitHub</a>
            <span class="sep">·</span>
            <a href="/getting-started/introduction">Docs</a>
        </footer>
    </div>
</body>
</html>

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    :root {
        --bg: hsl(220, 18%, 6%);
        --bg-elevated: hsl(220, 14%, 10%);
        --border: hsl(220, 10%, 18%);
        --text: hsl(0, 0%, 92%);
        --text-muted: hsl(220, 8%, 55%);
        --accent: hsl(145, 55%, 38%);
        --accent-high: hsl(145, 60%, 58%);
        --glow: hsla(145, 55%, 38%, 0.12);
        --font-mono: 'JetBrains Mono', ui-monospace, monospace;
        --font-sans: system-ui, -apple-system, sans-serif;
    }

    body {
        background: var(--bg);
        color: var(--text);
        font-family: var(--font-sans);
        min-height: 100vh;
    }

    .page {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
    }

    /* Header */
    header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.75rem 2rem;
        border-bottom: 1px solid var(--border);
        background: hsla(220, 16%, 8%, 0.9);
        backdrop-filter: blur(12px);
        position: sticky;
        top: 0;
        z-index: 100;
    }

    .logo-link {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        text-decoration: none;
        color: var(--text);
    }

    .logo-text {
        font-family: var(--font-mono);
        font-size: 0.85rem;
        font-weight: 600;
        letter-spacing: -0.01em;
    }

    nav {
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }

    nav a {
        color: var(--text-muted);
        text-decoration: none;
        font-size: 0.85rem;
        font-weight: 500;
        transition: color 0.15s ease;
    }

    nav a:hover {
        color: var(--text);
    }

    nav a.active {
        color: var(--accent-high);
    }

    /* Main */
    main {
        flex: 1;
        padding: 2rem;
        max-width: 1200px;
        margin: 0 auto;
        width: 100%;
    }

    .hero-section {
        text-align: center;
        margin-bottom: 2rem;
    }

    h1 {
        font-size: 2rem;
        font-weight: 800;
        margin-bottom: 0.5rem;
        background: linear-gradient(135deg, #4ade80, #22c55e, #16a34a);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .subtitle {
        color: var(--text-muted);
        font-size: 0.95rem;
        max-width: 550px;
        margin: 0 auto;
        line-height: 1.6;
    }

    /* 24-hour window callout */
    .callout {
        display: flex;
        gap: 0.85rem;
        padding: 1rem 1.25rem;
        margin-bottom: 1.5rem;
        background: hsla(200, 60%, 40%, 0.08);
        border: 1px solid hsla(200, 60%, 40%, 0.2);
        border-radius: 10px;
        border-left: 3px solid hsl(200, 60%, 50%);
    }

    .callout-icon {
        font-size: 1.3rem;
        line-height: 1;
        flex-shrink: 0;
    }

    .callout-content {
        font-size: 0.82rem;
        line-height: 1.6;
        color: var(--text-muted);
    }

    .callout-content strong {
        display: block;
        color: hsl(200, 60%, 70%);
        font-size: 0.85rem;
        margin-bottom: 0.25rem;
    }

    .callout-content p {
        margin: 0;
    }

    .callout-content a {
        color: hsl(200, 70%, 65%);
        text-decoration: underline;
        text-underline-offset: 2px;
    }

    .callout-content a:hover {
        color: hsl(200, 80%, 75%);
    }

    .callout-content code {
        padding: 0.1rem 0.35rem;
        background: hsla(200, 60%, 40%, 0.12);
        border: 1px solid hsla(200, 60%, 40%, 0.15);
        border-radius: 3px;
        font-family: var(--font-mono);
        font-size: 0.78rem;
    }

    /* Playground wrapper */
    .playground-wrapper {
        margin-bottom: 2.5rem;
    }

    /* Info cards */
    .info-section {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .info-card {
        position: relative;
        padding: 1.25rem 1.25rem 1.25rem 1.25rem;
        background: var(--bg-elevated);
        border: 1px solid var(--border);
        border-radius: 10px;
        transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }

    .info-card:hover {
        border-color: hsla(145, 55%, 38%, 0.3);
        box-shadow: 0 0 20px var(--glow);
    }

    .info-card-step {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 26px;
        height: 26px;
        margin-bottom: 0.65rem;
        background: hsla(145, 55%, 38%, 0.12);
        border: 1px solid hsla(145, 55%, 38%, 0.25);
        border-radius: 50%;
        font-family: var(--font-mono);
        font-size: 0.72rem;
        font-weight: 700;
        color: var(--accent-high);
    }

    .info-card h3 {
        font-family: var(--font-mono);
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--accent-high);
        text-transform: uppercase;
        letter-spacing: 0.04em;
        margin-bottom: 0.5rem;
    }

    .info-card p {
        color: var(--text-muted);
        font-size: 0.85rem;
        line-height: 1.5;
    }

    .info-card a {
        color: var(--accent-high);
        text-decoration: underline;
        text-underline-offset: 2px;
    }

    .info-card a:hover {
        color: var(--text);
    }

    /* Footer */
    footer {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        padding: 1.25rem 2rem;
        border-top: 1px solid var(--border);
        color: var(--text-muted);
        font-size: 0.75rem;
        font-family: var(--font-mono);
    }

    footer a {
        color: var(--text-muted);
        text-decoration: none;
        transition: color 0.15s ease;
    }

    footer a:hover {
        color: var(--accent-high);
    }

    .sep {
        opacity: 0.3;
    }

    /* Responsive */
    @media (max-width: 768px) {
        header {
            padding: 0.75rem 1rem;
        }

        nav {
            gap: 1rem;
        }

        main {
            padding: 1.5rem 1rem;
        }

        h1 {
            font-size: 1.5rem;
        }

        .info-section {
            grid-template-columns: 1fr;
        }
    }
</style>
