---
import StarlightHead from '@astrojs/starlight/components/Head.astro';
import type { Props } from '@astrojs/starlight/props';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';

const gaId = import.meta.env.PUBLIC_GA_ID;
---

<StarlightHead {...Astro.props} />
<Analytics />
<SpeedInsights />

{/* JetBrains Mono for terminal-style code blocks */}
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />

{/* OG Image (og:title, og:description, og:url, og:type, twitter:card are provided by Starlight) */}
<meta property="og:image" content="https://meta-cloud-api.site/og-image-1200x630.png" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content="meta-cloud-api — WhatsApp TypeScript SDK" />
<meta property="og:image" content="https://meta-cloud-api.site/og-image-square.png" />
<meta property="og:image:width" content="600" />
<meta property="og:image:height" content="600" />
<meta property="og:image:alt" content="meta-cloud-api — WhatsApp TypeScript SDK" />
<meta name="twitter:image" content="https://meta-cloud-api.site/og-image-1200x630.png" />

{/* JSON-LD structured data */}
<script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareSourceCode",
    "name": "meta-cloud-api",
    "description": "WhatsApp TypeScript SDK",
    "url": "https://meta-cloud-api.site",
    "codeRepository": "https://github.com/froggy1014/meta-cloud-api",
    "programmingLanguage": "TypeScript",
    "runtimePlatform": "Node.js",
    "license": "https://opensource.org/licenses/ISC",
    "operatingSystem": "Cross-platform",
})} />

{/* Google Analytics (GA4) */}
{gaId && (
    <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script is:inline define:vars={{ gaId }}>
            window.dataLayer = window.dataLayer || [];
            function gtag() { dataLayer.push(arguments); }
            gtag('js', new Date());
            gtag('config', gaId);
        </script>
    </>
)}
